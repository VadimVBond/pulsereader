---
export interface Props {
  title: string;
  excerpt: string;
  href: string;
  linkLabel?: string;
  publishedAt?: string;
  imageSrc?: string;
  category?: string;
  source?: string;
  compact?: boolean;
  imageUnavailableLabel?: string;
}

const {
  title,
  excerpt,
  href,
  linkLabel = 'Read article',
  publishedAt,
  imageSrc,
  category = 'Category',
  source = 'Source',
  compact = false,
  imageUnavailableLabel
} = Astro.props;
---

<article class:list={['article-card', { compact }]}>
  <a class='thumb' href={href} aria-label={title}>
    {imageSrc ? <img src={imageSrc} alt={title} loading='lazy' /> : <div class='thumb-fallback'>{imageUnavailableLabel || 'Изображение недоступно в источнике'}</div>}
  </a>

  <div class='card-body'>
    <p class='article-category'>{category}</p>

    <h3 class='article-title'>
      <a href={href}>{title}</a>
    </h3>

    <p class='article-excerpt'>{excerpt}</p>

    <div class='card-meta'>
      <span class='meta-dot' aria-hidden='true'></span>
      <span>{source}</span>
      {publishedAt && <span class='meta-sep'>•</span>}
      {publishedAt && <span>{publishedAt}</span>}
    </div>

    <a class='article-link' href={href}>{linkLabel}</a>
  </div>
</article>

<style>
  .article-card {
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--card-bg);
    display: grid;
    grid-template-rows: auto 1fr;
  }

  .thumb {
    display: block;
    aspect-ratio: 16 / 9;
    background: var(--thumb-bg);
  }

  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .thumb-fallback {
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
    text-align: center;
    padding: 0.75rem;
    color: var(--text-muted);
    font-size: 0.78rem;
    line-height: 1.35;
    text-transform: none;
    background: linear-gradient(180deg, rgba(8, 16, 34, 0.75), rgba(8, 16, 34, 0.95));
  }

  .card-body {
    padding: 0.75rem 0.85rem 0.85rem;
    display: grid;
    gap: 0.45rem;
    align-content: start;
  }

  .article-category {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.72rem;
  }

  .article-title {
    margin: 0;
    font-size: 1rem;
    line-height: 1.35;
  }

  .article-title a {
    text-decoration: none;
    color: var(--text-primary);
  }

  .article-title a:hover {
    color: var(--primary);
  }

  .article-excerpt {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.8rem;
    line-height: 1.45;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-meta {
    margin-top: 0.15rem;
    display: flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--text-muted);
    font-size: 0.75rem;
  }

  .meta-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--meta-dot);
    opacity: 0.9;
  }

  .meta-sep {
    opacity: 0.7;
  }

  .article-link {
    margin-top: 0.3rem;
    width: fit-content;
    font-size: 0.78rem;
    font-weight: 600;
    text-decoration: none;
    color: var(--primary);
  }

  .article-link:hover {
    text-decoration: underline;
  }

  .compact .card-body {
    gap: 0.4rem;
    padding: 0.65rem 0.75rem 0.75rem;
  }

  .compact .article-title {
    font-size: 0.95rem;
  }
</style>



