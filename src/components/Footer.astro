---
export interface FooterLink {
  label: string;
  href: string;
}

export interface Props {
  text?: string;
  links?: FooterLink[];
}

const currentYear = new Date().getFullYear();
const {
  text = `© ${currentYear} PulseReader. All rights reserved.`,
  links = []
} = Astro.props;
---

<footer class='footer'>
  <p>{text}</p>

  {links.length > 0 && (
    <ul class='links'>
      {links.map((link) => (
        <li>
          <a href={link.href}>{link.label}</a>
        </li>
      ))}
    </ul>
  )}
</footer>

<style>
  .footer {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.25rem;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 0 2rem;
    border-top: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .footer p {
    margin: 0;
  }

  .links {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    gap: 1rem;
  }

  .links a {
    color: inherit;
    text-decoration: none;
  }

  .links a:hover {
    color: var(--text-primary);
  }
</style>
