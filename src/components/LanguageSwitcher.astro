---
import type { Locale } from '../i18n';
import { LOCALES } from '../i18n';

export interface Props {
  locale: Locale;
  path?: string;
}

const { locale, path = '/' } = Astro.props;

const withoutLocale = path.replace(/^\/(en|uk|ru)(?=\/|$)/, '') || '/';

const makeHref = (target: Locale) => {
  if (target === 'ru') {
    return withoutLocale;
  }

  return `/${target}${withoutLocale === '/' ? '' : withoutLocale}`;
};
---

<nav class='lang-switcher' aria-label='Language switcher'>
  {
    LOCALES.map((code) => (
      <a class:list={['lang-link', { active: code === locale }]} href={makeHref(code)}>{code.toUpperCase()}</a>
    ))
  }
</nav>

<style>
  .lang-switcher {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--border);
    border-radius: 999px;
    overflow: hidden;
    background: var(--surface);
  }

  .lang-link {
    padding: 0.35rem 0.55rem;
    font-size: 0.72rem;
    text-decoration: none;
    color: var(--text-muted);
    border-right: 1px solid var(--border);
  }

  .lang-link:last-child {
    border-right: 0;
  }

  .lang-link.active {
    color: #fff;
    background: var(--primary);
  }
</style>
