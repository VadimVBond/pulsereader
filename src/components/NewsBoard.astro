---
import ArticleCard from './ArticleCard.astro';
import type { PipelineResult } from '../news/pipeline';
import type { NewsSource } from '../news/sources';
import type { Locale } from '../i18n';
import { getUiText, localePrefix } from '../i18n';

export interface Props {
  pipeline: PipelineResult;
  sources: NewsSource[];
  selectedSourceId?: string;
  locale?: Locale;
}

const { pipeline, sources, selectedSourceId, locale = 'ru' } = Astro.props;

const t = getUiText(locale);
const prefix = localePrefix(locale);

const articles = pipeline.articles;
const trending = articles.filter((article) => Boolean(article.imageUrl)).slice(0, 3);
const trendingSlugs = new Set(trending.map((article) => article.slug));
const moreStories = articles.filter((article) => !trendingSlugs.has(article.slug)).slice(0, 8);
const hasNews = articles.length > 0;

const activeSource = selectedSourceId ? sources.find((source) => source.id === selectedSourceId) : null;
const showingLabel = activeSource ? activeSource.name : t.allSources;

const selectedSourceError = selectedSourceId
  ? pipeline.errors.find((error) => error.sourceId === selectedSourceId)
  : null;

const compactError = (value: string) =>
  value
    .replace(/\s*\|\s*/g, '; ')
    .replace(/https?:\/\/\S+\s*->\s*/g, '')
    .slice(0, 220);

const formatDate = (value?: Date) =>
  value
    ? value.toLocaleDateString(locale === 'en' ? 'en-US' : locale === 'uk' ? 'uk-UA' : 'ru-RU', {
        day: '2-digit',
        month: 'short',
        year: 'numeric'
      })
    : undefined;

const localizeCategory = (category: string) => {
  if (category === 'Technology') {
    if (locale === 'ru') return 'Технологии';
    if (locale === 'uk') return 'Технології';
  }

  if (category === 'News') {
    if (locale === 'ru') return 'Новости';
    if (locale === 'uk') return 'Новини';
  }

  if (category === 'Sports') {
    return locale === 'en' ? 'Sports' : 'Спорт';
  }

  if (category === 'Culture') {
    return locale === 'en' ? 'Culture' : 'Культура';
  }

  return category;
};

const categories = [
  { id: 'all', label: locale === 'en' ? 'All' : locale === 'uk' ? 'Усі' : 'Все' },
  { id: 'News', label: localizeCategory('News') },
  { id: 'Technology', label: localizeCategory('Technology') },
  { id: 'Sports', label: localizeCategory('Sports') },
  { id: 'Culture', label: localizeCategory('Culture') }
];

const searchEmptyText =
  locale === 'en'
    ? 'No articles match your search.'
    : locale === 'uk'
      ? 'Немає статей за цим запитом.'
      : 'По вашему запросу статьи не найдены.';

const popularTagsByCategory = {
  all:
    locale === 'en'
      ? ['AI', 'Startups', 'Security', 'Gadgets', 'Space', 'Fintech', 'Gaming', 'Mobile']
      : locale === 'uk'
        ? ['ШІ', 'Стартапи', 'Безпека', 'Гаджети', 'Космос', 'Фінтех', 'Ігри', 'Мобільні']
        : ['ИИ', 'Стартапы', 'Безопасность', 'Гаджеты', 'Космос', 'Финтех', 'Игры', 'Мобильные'],
  News:
    locale === 'en'
      ? ['Politics', 'World', 'Ukraine', 'Economy', 'Energy', 'Diplomacy', 'Elections', 'Markets']
      : locale === 'uk'
        ? ['Політика', 'Світ', 'Україна', 'Економіка', 'Енергія', 'Дипломатія', 'Вибори', 'Ринки']
        : ['Политика', 'Мир', 'Украина', 'Экономика', 'Энергетика', 'Дипломатия', 'Выборы', 'Рынки'],
  Technology:
    locale === 'en'
      ? ['AI', 'Startups', 'Cloud', 'Security', 'Apps', 'Hardware', 'Web', 'Mobile']
      : locale === 'uk'
        ? ['ШІ', 'Стартапи', 'Хмара', 'Безпека', 'Додатки', 'Залізо', 'Веб', 'Мобільні']
        : ['ИИ', 'Стартапы', 'Облако', 'Безопасность', 'Приложения', 'Железо', 'Веб', 'Мобильные'],
  Sports:
    locale === 'en'
      ? ['Football', 'Tennis', 'Basketball', 'Boxing', 'Formula 1', 'Olympics', 'Transfers', 'Results']
      : locale === 'uk'
        ? ['Футбол', 'Теніс', 'Баскетбол', 'Бокс', 'Формула 1', 'Олімпіада', 'Трансфери', 'Результати']
        : ['Футбол', 'Теннис', 'Баскетбол', 'Бокс', 'Формула 1', 'Олимпиада', 'Трансферы', 'Результаты'],
  Culture:
    locale === 'en'
      ? ['Movies', 'Music', 'Books', 'Art', 'Theatre', 'Festivals', 'Reviews', 'Interviews']
      : locale === 'uk'
        ? ['Кіно', 'Музика', 'Книги', 'Мистецтво', 'Театр', 'Фестивалі', 'Огляди', 'Інтерв’ю']
        : ['Кино', 'Музыка', 'Книги', 'Искусство', 'Театр', 'Фестивали', 'Обзоры', 'Интервью']
};

const sourceHref = (id: string) => `${prefix}/source/${id}`;
const articleHref = (slug: string) => `${prefix}/article/${slug}`;
const homeHref = prefix;
---

<div class='page-shell' data-search-root>
  <section class='category-panel' aria-label='Category filters'>
    {categories.map((category) => (
      <button
        type='button'
        class:list={['category-chip', { active: category.id === 'all' }]}
        data-category={category.id}
      >
        {category.label}
      </button>
    ))}
  </section>

  <section class='search-panel' aria-label='Source filters'>
    <div class='chips'>
      <a class:list={['chip', { active: !selectedSourceId }]} href={homeHref} data-source-category='all'>{t.allSources}</a>
      {
        sources.map((source) => (
          <a
            class:list={['chip', { active: selectedSourceId === source.id }]}
            href={sourceHref(source.id)}
            data-source-category={source.category}
          >
            {source.name}
          </a>
        ))
      }
    </div>

    <div class='search-toolbar'>
      <div class='search-input-group'>
        <input type='search' placeholder={t.searchPlaceholder} aria-label={t.searchPlaceholder} data-search-input />
        <button type='button' class='search-btn' data-search-button>{t.searchButton}</button>
      </div>

      <div class='popular-tags' aria-label='Popular search tags'>
        {Object.entries(popularTagsByCategory).map(([key, tags]) => (
          <div class='tag-group' data-tag-group={key} hidden={key !== 'all'}>
            {tags.map((tag) => (
              <button type='button' class='tag' data-tag={tag}>{tag}</button>
            ))}
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class='stats-row' aria-label='Stats'>
    <article class='stat-card'><strong data-found-count>{articles.length}</strong><span>{t.articlesFound}</span></article>
    <article class='stat-card'><strong>{pipeline.sources.length}</strong><span>{t.sourcesUsed}</span></article>
    <article class='stat-card'><strong>{pipeline.totalDuplicatesRemoved}</strong><span>{t.duplicatesRemoved}</span></article>
  </section>

  <p class='source-indicator'>
    {t.showingFrom}: <strong>{showingLabel}</strong>
  </p>

  {
    selectedSourceError && (
      <p class='source-error'>
        <strong>{t.sourceUnavailable}.</strong> {t.sourceUnavailableDetails}: {compactError(selectedSourceError.error)}
      </p>
    )
  }

  <p class='search-empty' data-search-empty hidden>{searchEmptyText}</p>

  {
    !hasNews && (
      <section class='empty-state'>
        <h2>{t.noNewsTitle}</h2>
        <p>{t.noNewsText}</p>
      </section>
    )
  }

  {
    hasNews && (
      <>
        <section class='section-block'>
          <h2>{t.trending}</h2>
          <div class='trending-grid'>
            {
              trending.map((article) => {
                const category = localizeCategory(article.sourceCategory);
                const haystack = `${article.title} ${article.excerpt} ${article.sourceName} ${category}`.toLowerCase();

                return (
                  <div
                    class='article-item'
                    data-card
                    data-haystack={haystack}
                    data-category={article.sourceCategory}
                  >
                    <ArticleCard
                      title={article.title}
                      excerpt={article.excerpt}
                      href={articleHref(article.slug)}
                      linkLabel={t.readArticle}
                      publishedAt={formatDate(article.publishedAt)}
                      imageSrc={article.imageUrl}
                      category={category}
                      source={article.sourceName}
                      imageUnavailableLabel={t.imageUnavailable}
                    />
                  </div>
                );
              })
            }
          </div>
        </section>

        <section class='section-block'>
          <h2>{t.moreStories}</h2>
          <div class='stories-grid'>
            {
              moreStories.map((article) => {
                const category = localizeCategory(article.sourceCategory);
                const haystack = `${article.title} ${article.excerpt} ${article.sourceName} ${category}`.toLowerCase();

                return (
                  <div
                    class='article-item'
                    data-card
                    data-haystack={haystack}
                    data-category={article.sourceCategory}
                  >
                    <ArticleCard
                      title={article.title}
                      excerpt={article.excerpt}
                      href={articleHref(article.slug)}
                      linkLabel={t.readArticle}
                      publishedAt={formatDate(article.publishedAt)}
                      imageSrc={article.imageUrl}
                      category={category}
                      source={article.sourceName}
                      compact={true}
                      imageUnavailableLabel={t.imageUnavailable}
                    />
                  </div>
                );
              })
            }
          </div>
        </section>
      </>
    )
  }
</div>

<script is:inline>
  (() => {
    const root = document.querySelector('[data-search-root]');
    if (!root) return;

    const input = root.querySelector('[data-search-input]');
    const button = root.querySelector('[data-search-button]');
    const cards = Array.from(root.querySelectorAll('[data-card]'));
    const foundCount = root.querySelector('[data-found-count]');
    const emptyState = root.querySelector('[data-search-empty]');
    const tags = Array.from(root.querySelectorAll('[data-tag]'));
    const categoryButtons = Array.from(root.querySelectorAll('[data-category]'));
    const sourceChips = Array.from(root.querySelectorAll('[data-source-category]'));
    const tagGroups = Array.from(root.querySelectorAll('[data-tag-group]'));

    if (!input || !button || cards.length === 0 || !foundCount || !emptyState) return;

    let activeCategory = 'all';

    const normalize = (value) => value.toLowerCase().trim();

    const updateTags = () => {
      tagGroups.forEach((group) => {
        group.hidden = group.getAttribute('data-tag-group') !== activeCategory;
      });
    };

    const updateSources = () => {
      sourceChips.forEach((chip) => {
        const category = chip.getAttribute('data-source-category') || 'all';
        chip.hidden = activeCategory !== 'all' && category !== activeCategory;
      });
    };

    const applySearch = () => {
      const query = normalize(input.value || '');
      let visibleCount = 0;

      for (const card of cards) {
        const haystack = normalize(card.getAttribute('data-haystack') || '');
        const category = card.getAttribute('data-category') || 'all';
        const matchesCategory = activeCategory === 'all' || category === activeCategory;
        const matched = (!query || haystack.includes(query)) && matchesCategory;
        card.hidden = !matched;
        if (matched) visibleCount += 1;
      }

      foundCount.textContent = String(visibleCount);
      emptyState.hidden = visibleCount !== 0;
    };

    const setActiveCategory = (category) => {
      activeCategory = category;
      categoryButtons.forEach((btn) => {
        btn.classList.toggle('active', btn.getAttribute('data-category') === category);
      });
      updateSources();
      updateTags();
      applySearch();
    };

    input.addEventListener('input', applySearch);
    input.addEventListener('keydown', (event) => {
      if (event.key === 'Enter') {
        event.preventDefault();
        applySearch();
      }
    });
    button.addEventListener('click', applySearch);
    tags.forEach((tag) => {
      tag.addEventListener('click', () => {
        input.value = tag.textContent || '';
        applySearch();
      });
    });
    categoryButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const category = btn.getAttribute('data-category') || 'all';
        setActiveCategory(category);
      });
    });

    setActiveCategory(activeCategory);
  })();
</script>

<style>
  .page-shell {
    background: var(--shell-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.2rem;
    display: grid;
    gap: 1rem;
  }

  .category-panel {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .category-chip {
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text-muted);
    border-radius: 999px;
    padding: 0.35rem 0.7rem;
    font-size: 0.8rem;
    cursor: pointer;
  }

  .category-chip.active {
    color: #fff;
    background: var(--primary);
    border-color: var(--primary);
  }

  .search-panel {
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--panel-bg);
    padding: 0.9rem;
    display: grid;
    gap: 0.75rem;
  }

  .search-toolbar {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .chips {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .chip {
    padding: 0.35rem 0.6rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    font-size: 0.75rem;
    color: var(--text-muted);
    background: var(--chip-bg);
    text-decoration: none;
  }

  .chip.active {
    color: #fff;
    background: var(--primary);
    border-color: var(--primary);
  }

  .search-input-group {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    min-width: min(360px, 100%);
    flex: 1 1 360px;
  }

  .search-input-group input {
    width: min(420px, 100%);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.45rem 0.6rem;
    font-size: 0.88rem;
    background: var(--input-bg);
    color: var(--text-primary);
  }

  .search-btn {
    border: 0;
    border-radius: 8px;
    background: #3b82f6;
    color: #fff;
    padding: 0.35rem 0.85rem;
    font-weight: 600;
    cursor: pointer;
  }

  .popular-tags {
    display: grid;
    grid-template-columns: repeat(1, minmax(0, 1fr));
    gap: 0.45rem;
    justify-items: end;
    flex: 0 1 auto;
    margin-left: auto;
  }

  .tag-group {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.45rem;
  }

  .tag {
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--surface);
    color: var(--text-muted);
    padding: 0.2rem 0.55rem;
    font-size: 0.7rem;
    cursor: pointer;
    white-space: nowrap;
  }

  .tag:hover {
    color: var(--text-primary);
    border-color: var(--primary);
  }

  .stats-row {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.7rem;
  }

  .stat-card {
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--surface);
    padding: 0.6rem 0.75rem;
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
  }

  .stat-card strong {
    font-size: 1.15rem;
    line-height: 1;
  }

  .stat-card span {
    color: var(--text-muted);
    font-size: 0.82rem;
  }

  .source-indicator {
    margin: -0.1rem 0 0;
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  .source-indicator strong {
    color: var(--text-primary);
    font-weight: 600;
  }

  .source-error {
    margin: -0.2rem 0 0;
    color: #fca5a5;
    font-size: 0.82rem;
  }

  .search-empty {
    margin: -0.2rem 0 0;
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .empty-state {
    border: 1px dashed var(--border);
    border-radius: 10px;
    padding: 1rem;
  }

  .empty-state h2 {
    margin: 0;
    font-size: 1.15rem;
  }

  .empty-state p {
    margin: 0.45rem 0 0;
    color: var(--text-muted);
  }

  .section-block {
    display: grid;
    gap: 0.7rem;
  }

  .section-block h2 {
    margin: 0;
    font-size: 1.2rem;
    color: var(--text-primary);
  }

  .trending-grid {
    display: grid;
    gap: 0.85rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .stories-grid {
    display: grid;
    gap: 0.85rem;
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  @media (max-width: 1000px) {
    .trending-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .stories-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .tag-group {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .page-shell {
      padding: 0.9rem;
    }

    .stats-row,
    .trending-grid,
    .stories-grid {
      grid-template-columns: 1fr;
    }

    .search-input-group {
      width: 100%;
    }

    .tag-group {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .popular-tags {
      justify-items: start;
      width: 100%;
    }
  }
</style>
