---
export interface Props {
  label?: string;
  storageKey?: string;
}

const { label = 'Toggle theme', storageKey = 'theme' } = Astro.props;
---

<button
  type='button'
  class='theme-toggle'
  aria-label={label}
  data-theme-toggle
  data-storage-key={storageKey}
>
  <span data-theme-icon aria-hidden='true'>◐</span>
  <span data-theme-label>Theme</span>
</button>

<script is:inline>
  (() => {
    const getPreferredTheme = () => {
      return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    };

    const applyTheme = (theme) => {
      document.documentElement.dataset.theme = theme;
    };

    const getInitialTheme = (key) => {
      const savedTheme = window.localStorage.getItem(key);
      return savedTheme === 'dark' || savedTheme === 'light' ? savedTheme : getPreferredTheme();
    };

    const setToggleLabel = (button, theme) => {
      const nextTheme = theme === 'dark' ? 'light' : 'dark';
      const textNode = button.querySelector('[data-theme-label]');
      if (textNode) {
        textNode.textContent = nextTheme === 'dark' ? 'Dark' : 'Light';
      }

      button.setAttribute('aria-pressed', String(theme === 'dark'));
      button.setAttribute('title', `Switch to ${nextTheme} theme`);
    };

    const bindToggle = (button) => {
      if (!(button instanceof HTMLElement) || button.dataset.themeBound === 'true') {
        return;
      }

      const storageKey = button.dataset.storageKey || 'theme';
      const initialTheme = getInitialTheme(storageKey);
      applyTheme(initialTheme);
      setToggleLabel(button, initialTheme);

      button.addEventListener('click', () => {
        const currentTheme = document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';
        const nextTheme = currentTheme === 'dark' ? 'light' : 'dark';

        applyTheme(nextTheme);
        window.localStorage.setItem(storageKey, nextTheme);
        setToggleLabel(button, nextTheme);
      });

      button.dataset.themeBound = 'true';
    };

    const initThemeToggles = () => {
      document.querySelectorAll('[data-theme-toggle]').forEach((button) => bindToggle(button));
    };

    if (!window.__pulseThemeInitBound) {
      window.__pulseThemeInitBound = true;
      document.addEventListener('astro:page-load', initThemeToggles);
      document.addEventListener('DOMContentLoaded', initThemeToggles);
    }

    initThemeToggles();
  })();
</script>

<style>
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--surface);
    color: var(--text-primary);
    padding: 0.45rem 0.75rem;
    font-size: 0.85rem;
    line-height: 1;
    cursor: pointer;
  }

  .theme-toggle:hover {
    border-color: var(--primary);
  }

  [data-theme-icon] {
    font-size: 0.95rem;
  }
</style>
