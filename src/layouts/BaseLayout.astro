---
import '../styles/global.css';
import Container from '../components/Container.astro';
import Header, { type NavLink } from '../components/Header.astro';
import Footer, { type FooterLink } from '../components/Footer.astro';
import ThemeToggle from '../components/ThemeToggle.astro';

export interface Props {
  title?: string;
  description?: string;
  lang?: string;
  showHeader?: boolean;
  showFooter?: boolean;
  containerSize?: 'sm' | 'md' | 'lg';
  navLinks?: NavLink[];
  footerLinks?: FooterLink[];
  image?: string;
  noindex?: boolean;
}

const {
  title = 'PulseReader',
  description = 'PulseReader news and articles.',
  lang = 'ru',
  showHeader = true,
  showFooter = true,
  containerSize = 'lg',
  navLinks,
  footerLinks,
  image,
  noindex = false
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const baseUrl = import.meta.env.BASE_URL || '/';
const homeHref = baseUrl === '/' ? '/' : baseUrl.replace(/\/$/, '');
const defaultImagePath = `${baseUrl}images/og-default.svg`;
const imageUrl = new URL(image ?? defaultImagePath, Astro.site).toString();
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset='utf-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1' />
    <title>{title}</title>

    <meta name='description' content={description} />
    <meta name='robots' content={noindex ? 'noindex, nofollow' : 'index, follow'} />
    <link rel='canonical' href={canonicalUrl} />

    <meta property='og:type' content='website' />
    <meta property='og:title' content={title} />
    <meta property='og:description' content={description} />
    <meta property='og:url' content={canonicalUrl} />
    <meta property='og:image' content={imageUrl} />

    <meta name='twitter:card' content='summary_large_image' />
    <meta name='twitter:title' content={title} />
    <meta name='twitter:description' content={description} />
    <meta name='twitter:image' content={imageUrl} />
  </head>
  <body>
    <Container as='div' size={containerSize}>
      {
        showHeader && (
          <Header links={navLinks} homeHref={homeHref}>
            <slot name='header-actions' slot='actions'>
              <ThemeToggle />
            </slot>
          </Header>
        )
      }

      <main>
        <slot />
      </main>

      {showFooter && <Footer links={footerLinks} />}
    </Container>
  </body>
</html>

<style>
  main {
    padding: 1.5rem 0 2rem;
  }
</style>
