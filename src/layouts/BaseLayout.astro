---
import '../styles/global.css';
import Container from '../components/Container.astro';
import Header, { type NavLink } from '../components/Header.astro';
import Footer, { type FooterLink } from '../components/Footer.astro';

export interface Props {
  title?: string;
  description?: string;
  lang?: string;
  showHeader?: boolean;
  showFooter?: boolean;
  containerSize?: 'sm' | 'md' | 'lg';
  navLinks?: NavLink[];
  footerLinks?: FooterLink[];
}

const {
  title = 'PulseReader',
  description = 'PulseReader news and articles.',
  lang = 'ru',
  showHeader = true,
  showFooter = true,
  containerSize = 'lg',
  navLinks,
  footerLinks
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset='utf-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1' />
    <meta name='description' content={description} />
    <title>{title}</title>
  </head>
  <body>
    <Container as='div' size={containerSize}>
      {showHeader && <Header links={navLinks}><slot name='header-actions' slot='actions' /></Header>}
      <main>
        <slot />
      </main>
      {showFooter && <Footer links={footerLinks} />}
    </Container>
  </body>
</html>

<style>
  main {
    padding: 1.5rem 0 2rem;
  }
</style>
