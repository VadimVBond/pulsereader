---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ThemeToggle from '../../../components/ThemeToggle.astro';
import LanguageSwitcher from '../../../components/LanguageSwitcher.astro';
import { runNewsPipeline, type PipelineArticle } from '../../../news/pipeline';
import { LOCALES, type Locale, getUiText, isLocale, localePrefix } from '../../../i18n';

export async function getStaticPaths() {
  const langs = LOCALES.filter((locale) => locale !== 'ru');
  const paths = [] as Array<{ params: { lang: string; slug: string }; props: { locale: Locale; article: PipelineArticle } }>;

  for (const locale of langs) {
    const result = await runNewsPipeline({ limit: 120, locale });
    for (const article of result.articles) {
      paths.push({
        params: { lang: locale, slug: article.slug },
        props: { locale, article }
      });
    }
  }

  return paths;
}

const { locale, article } = Astro.props as { locale: Locale; article: PipelineArticle };

if (!isLocale(locale) || locale === 'ru') {
  throw new Error('Unsupported locale route');
}

const t = getUiText(locale);
const prefix = localePrefix(locale);
const localeTag = locale === 'en' ? 'en-US' : 'uk-UA';
const publishedAt = article.publishedAt
  ? article.publishedAt.toLocaleDateString(localeTag, {
      day: '2-digit',
      month: 'long',
      year: 'numeric'
    })
  : null;

const navLinks = [
  { label: t.navHome, href: `${prefix || '/'}` },
  { label: t.navCategories, href: '#' },
  { label: t.navAbout, href: '#' },
  { label: t.navContact, href: '#' }
];
---

<BaseLayout title={`PulseReader | ${article.title}`} description={article.excerpt} containerSize='md' lang={locale} navLinks={navLinks}>
  <Fragment slot='header-actions'>
    <LanguageSwitcher locale={locale} path={Astro.url.pathname} />
    <ThemeToggle />
  </Fragment>

  <article class='article-page'>
    <header class='article-head'>
      <p class='article-kicker'>{article.sourceName}</p>
      <h1>{article.title}</h1>
      {publishedAt && <p class='article-date'>{publishedAt}</p>}
      <p class='article-excerpt'>{article.excerpt}</p>
    </header>

    <section class='article-body'>
      <p>{article.excerpt}</p>
      <p>{t.aggregatedNote}</p>
      <p>
        <a href={article.url} target='_blank' rel='noopener noreferrer'>{t.readOriginal}</a>
      </p>
    </section>

    <p class='article-back'>
      <a href={`${prefix || '/'}`}>{t.backHome}</a>
    </p>
  </article>
</BaseLayout>

<style>
  .article-page {
    display: grid;
    gap: 1rem;
  }

  .article-head h1 {
    margin: 0;
    font-size: clamp(1.7rem, 2.8vw, 2.2rem);
  }

  .article-kicker {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.9rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .article-date {
    margin: 0.5rem 0 0;
    color: var(--text-muted);
    font-size: 0.88rem;
  }

  .article-excerpt {
    margin: 0.4rem 0 0;
    color: var(--text-muted);
  }

  .article-body p {
    margin: 0 0 1rem;
    line-height: 1.75;
  }

  .article-body a,
  .article-back a {
    color: var(--primary);
    text-decoration: none;
  }

  .article-body a:hover,
  .article-back a:hover {
    text-decoration: underline;
  }

  .article-back {
    margin: 0.75rem 0 0;
  }
</style>
