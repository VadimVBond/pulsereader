---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ThemeToggle from '../../components/ThemeToggle.astro';
import LanguageSwitcher from '../../components/LanguageSwitcher.astro';
import { runNewsPipeline, type PipelineArticle } from '../../news/pipeline';
import { getUiText } from '../../i18n';

const locale = 'ru';
const t = getUiText(locale);

export async function getStaticPaths() {
  const result = await runNewsPipeline({ limit: 120, locale: 'ru' });

  return result.articles.map((article) => ({
    params: { slug: article.slug },
    props: { article }
  }));
}

const { article } = Astro.props as { article: PipelineArticle };

const publishedAt = article.publishedAt
  ? article.publishedAt.toLocaleDateString('ru-RU', {
      day: '2-digit',
      month: 'long',
      year: 'numeric'
    })
  : null;

const navLinks = [
  { label: t.navHome, href: '/' },
  { label: t.navCategories, href: '#' },
  { label: t.navAbout, href: '#' },
  { label: t.navContact, href: '#' }
];
---

<BaseLayout title={`PulseReader | ${article.title}`} description={article.excerpt} containerSize='md' lang={locale} navLinks={navLinks}>
  <Fragment slot='header-actions'>
    <LanguageSwitcher locale={locale} path={Astro.url.pathname} />
    <ThemeToggle />
  </Fragment>

  <article class='article-page'>
    <header class='article-head'>
      <div class='article-head-top'>
        <p class='article-kicker'>{article.sourceName}</p>
        <div class='translate-controls' data-controls>
          <span>{t.translateDescription}:</span>
          <button type='button' class='translate-btn' data-lang='en'>EN</button>
          <button type='button' class='translate-btn' data-lang='uk'>UK</button>
          <button type='button' class='translate-btn' data-lang='ru'>RU</button>
        </div>
      </div>

      <h1 data-translatable='title' data-original={article.title}>{article.title}</h1>
      {publishedAt && <p class='article-date'>{publishedAt}</p>}
      <p class='article-excerpt' data-translatable='excerpt' data-original={article.excerpt}>{article.excerpt}</p>
    </header>

    <figure class='article-cover'>
      <img src={article.imageUrl ?? '/images/og-default.svg'} alt={article.title} loading='lazy' />
    </figure>

    <section class='article-body'>
      <p
        class='article-description'
        data-translatable='description'
        data-original={article.description}
        data-translating={t.translating}
      >
        {article.description}
      </p>

      <p>{t.aggregatedNote}</p>
      <p>
        <a href={article.url} target='_blank' rel='noopener noreferrer'>{t.readOriginal}</a>
      </p>
    </section>

    <p class='article-back'>
      <a href='/'>{t.backHome}</a>
    </p>
  </article>
</BaseLayout>

<script is:inline>
  (() => {
    const controls = document.querySelector('[data-controls]');
    if (!controls) return;

    const buttons = Array.from(controls.querySelectorAll('.translate-btn'));
    const targets = Array.from(document.querySelectorAll('[data-translatable]'));
    if (targets.length === 0) return;

    const translatingLabel =
      document.querySelector('[data-translatable="description"]')?.getAttribute('data-translating') || 'Translating...';

    const sourceText = {};
    for (const el of targets) {
      const key = el.getAttribute('data-translatable');
      if (!key) continue;
      sourceText[key] = el.getAttribute('data-original') || el.textContent || '';
    }

    const cache = {
      en: {},
      uk: {},
      ru: {}
    };

    async function translateText(text, target) {
      const endpoint = `https://translate.googleapis.com/translate_a/single?client=gtx&sl=auto&tl=${target}&dt=t&q=${encodeURIComponent(text)}`;
      const response = await fetch(endpoint);
      if (!response.ok) return text;

      const payload = await response.json();
      const translated = Array.isArray(payload?.[0])
        ? payload[0].map((chunk) => chunk?.[0] || '').join('')
        : text;

      return translated || text;
    }

    function setActive(lang) {
      buttons.forEach((btn) => btn.classList.toggle('active', btn.dataset.lang === lang));
    }

    async function applyLanguage(lang) {
      const langCache = cache[lang];

      const pending = [];
      for (const el of targets) {
        const key = el.getAttribute('data-translatable');
        if (!key) continue;

        if (langCache[key]) {
          el.textContent = langCache[key];
          continue;
        }

        pending.push({ el, key, original: sourceText[key] || '' });
      }

      for (const item of pending) {
        item.el.textContent = translatingLabel;
      }

      await Promise.all(
        pending.map(async (item) => {
          try {
            const translated = await translateText(item.original, lang);
            langCache[item.key] = translated;
            item.el.textContent = translated;
          } catch {
            item.el.textContent = item.original;
          }
        })
      );
    }

    buttons.forEach((button) => {
      button.addEventListener('click', async () => {
        const lang = button.dataset.lang;
        if (!lang) return;

        setActive(lang);
        await applyLanguage(lang);
      });
    });
  })();
</script>

<style>
  .article-page {
    display: grid;
    gap: 1rem;
  }

  .article-head-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  .article-head h1 {
    margin: 0;
    font-size: clamp(1.7rem, 2.8vw, 2.2rem);
  }

  .article-kicker {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.9rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .article-date {
    margin: 0.5rem 0 0;
    color: var(--text-muted);
    font-size: 0.88rem;
  }

  .article-excerpt {
    margin: 0.4rem 0 0;
    color: var(--text-muted);
  }

  .article-cover {
    margin: 0;
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    background: var(--thumb-bg);
  }

  .article-cover img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
  }

  .translate-controls {
    display: inline-flex;
    gap: 0.45rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .translate-controls span {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .translate-btn {
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text-primary);
    border-radius: 999px;
    padding: 0.25rem 0.5rem;
    font-size: 0.72rem;
    cursor: pointer;
  }

  .translate-btn.active {
    background: var(--primary);
    border-color: var(--primary);
    color: #fff;
  }

  .article-body p {
    margin: 0 0 1rem;
    line-height: 1.75;
  }

  .article-description {
    font-size: 1.05rem;
    font-weight: 500;
  }

  .article-body a,
  .article-back a {
    color: var(--primary);
    text-decoration: none;
  }

  .article-body a:hover,
  .article-back a:hover {
    text-decoration: underline;
  }

  .article-back {
    margin: 0.75rem 0 0;
  }
</style>



